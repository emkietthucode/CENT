# CEnt — Environment Variables Template
# Copy this file to .env.local for local development, or add these to Vercel Dashboard!

# 1. TMDB API Key (Get from themoviedb.org)
# (Fallbacks to default CEnt key if left empty, but recommended to use your own!)
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here

# 2. Supabase Settings (Get from supabase.com project settings -> API)
# (Required for Watched/Rating sync and Watchlist database persistence!)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 3. OMDB API Key (Get from omdbapi.com)
# (Used for IMDb & Rotten Tomatoes rating fallback fetching)
OMDB_API_KEY=your_omdb_api_key_here
